{
  "expo": {
    "name": "Carify – Panduan Cek Mobil",
    "slug": "carify_panduan_cek_mobil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/carify-icon.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/carify-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "rpl.skansaka.carify_panduan_cek_mobil"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/carify-icon_adaptive_fore.png",
        "backgroundColor": "#03A9F4"
      },
      "package": "rpl.skansaka.carify_panduan_cek_mobil"
    },
    "web": {
      "favicon": "./assets/images/favicon-carify.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Poppins-Medium.ttf",
            "./assets/fonts/Poppins-SemiBold.ttf",
            "./assets/fonts/Poppins-Bold.ttf",
            "./assets/fonts/Poppins-ExtraBold.ttf"
          ]
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://rork.com/"
      },
      "eas": {
        "projectId": "e7589c36-448a-4d5e-882f-fcb17387d8a6"
      }
    },
    "owner": ""
  }
}
